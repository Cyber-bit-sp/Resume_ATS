DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=ats_resume_generator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Set to 1 for local development without PostgreSQL.
USE_SQLITE=0

# Optional. If omitted, the backend uses the deterministic local generator.
OPENAI_API_KEY=
# Use gpt-4.1 for best resume-writing accuracy, or gpt-4.1-mini for lower cost.
OPENAI_MODEL=gpt-4.1
# If first GPT draft scores below this ATS score, run one GPT refinement pass.
OPENAI_REFINEMENT_MIN_SCORE=90

# Created automatically after migrations if no administrator exists.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@blue.com
DEFAULT_ADMIN_PASSWORD=qwe123QWE!@#
